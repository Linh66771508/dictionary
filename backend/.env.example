# SQLite database path (Render free: use local file)
SQLITE_DB_PATH=./data/dictionary.db

# PostgreSQL database URL (Render Postgres)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=
# Optional: force postgres even if DATABASE_URL is empty
DB_DRIVER=postgres

APP_HOST=0.0.0.0
APP_PORT=8000
